// Prisma schema for Elaine Confeitaria backend

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  tamanho   String?
  tipo      String?
  precoUnitario Float?
  anexo     Json?
  imagemUrl String?
  imagemAlt String?

  tpItems TPItem[]
  pItems  PItem[]

  @@map("Produto")
}

model Massa {
  id        Int      @id @default(autoincrement())
  descricao String

  @@map("Massa")
}

model Sabor {
  id        Int      @id @default(autoincrement())
  descricao String

  @@map("Sabores")
}

model Usuario {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  senha          String
  isAdmin        Boolean  @default(false)
  endereco       String?
  telefone       String?
  cpf            String?
  cnpj           String?
  dataNascimento String?

  pedidos Pedido[]

  @@map("Usuario")
}

model ConfiguracaoEntrega {
  id                 Int      @id @default(1)
  tempoMinimoMinutos Int
  tempoMaximoMinutos Int
  mensagemLivre      String?
  updatedByUsuarioId Int?
  updatedAt          DateTime @updatedAt

  @@map("ConfiguracaoEntrega")
}

model TabelaPreco {
  id         Int      @id @default(autoincrement())
  descricao  String
  dataInicio DateTime
  dataFim    DateTime?
  atual      Boolean  @default(false)

  itens TPItem[]

  @@map("TabelaPreco")
}

model TPItem {
  id            Int         @id @default(autoincrement())
  tabelaPreco   TabelaPreco @relation(fields: [tabelaPrecoId], references: [id])
  tabelaPrecoId Int
  produto       Produto     @relation(fields: [produtoId], references: [id])
  produtoId     Int
  preco         Float

  @@map("TPItem")
}

model Pedido {
  id                   Int      @id @default(autoincrement())
  usuario              Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId            Int
  nomeRecebedor        String?
  endereco             String
  complemento          String?
  referencia           String?
  tipoEntrega          String
  melhorHorarioEntrega String?
  observacoes          String?
  anexo                Json?
  valorTotal           Float
  desconto             Float?
  status               String

  itens PItem[]

  @@map("Pedido")
}

model PItem {
  id         Int     @id @default(autoincrement())
  pedido     Pedido  @relation(fields: [pedidoId], references: [id])
  pedidoId   Int
  produto    Produto @relation(fields: [produtoId], references: [id])
  produtoId  Int
  quantidade Int
  preco      Float

  @@map("PItem")
}
