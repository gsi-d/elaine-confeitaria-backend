{
  "info": {
    "_postman_id": "c20d90d6-f6b0-4cfe-a2d6-6fd0e80d7816",
    "name": "Elaine Confeitaria V1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "{{baseUrl}}" },
    { "key": "token", "value": "" },
    { "key": "pedidoId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@elaine.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Listar Pedidos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/pedidos"
          }
        },
        {
          "name": "Criar Pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('pedidoId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeRecebedor\": \"Maria\",\n  \"endereco\": \"Rua das Flores, 123\",\n  \"complemento\": \"Casa 2\",\n  \"referencia\": \"Portao branco\",\n  \"tipoEntrega\": \"ENTREGA\",\n  \"melhorHorarioEntrega\": \"18:30\",\n  \"observacoes\": \"Tocar interfone\",\n  \"desconto\": 5,\n  \"itens\": [\n    {\n      \"produtoId\": 1,\n      \"quantidade\": 2\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/pedidos"
          }
        },
        {
          "name": "Buscar Pedido",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}"
          }
        },
        {
          "name": "Atualizar Pedido",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\",\n  \"observacoes\": \"Sai hoje\",\n  \"desconto\": 3,\n  \"itens\": [\n    {\n      \"produtoId\": 1,\n      \"quantidade\": 1\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}"
          }
        },
        {
          "name": "Atualizar Status do Pedido",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SAIU_PARA_ENTREGA\"\n}"
            },
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}/status"
          }
        },
        {
          "name": "Excluir Pedido",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}"
          }
        }
      ]
    },
    {
      "name": "Catalogos",
      "item": [
        {
          "name": "Listar Produtos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/produtos"
          }
        },
        {
          "name": "Listar Massas",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/massas"
          }
        },
        {
          "name": "Listar Sabores",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/sabores"
          }
        },
        {
          "name": "Listar Tabelas de Preco",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tabelas-preco"
          }
        },
        {
          "name": "Listar Itens de Tabela",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tp-itens"
          }
        },
        {
          "name": "Buscar Configuracao de Entrega",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/configuracao-entrega"
          }
        },
        {
          "name": "Atualizar Configuracao de Entrega",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tempoMinimoMinutos\": 60,\n  \"tempoMaximoMinutos\": 90,\n  \"mensagemLivre\": \"Alta demanda no momento\"\n}"
            },
            "url": "{{baseUrl}}/configuracao-entrega"
          }
        }
      ]
    }
  ]
}
